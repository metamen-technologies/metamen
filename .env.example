# =============================================================================
# METAMEN100 — Environment Variables Template
# =============================================================================
# Copiar este archivo a .env.local y completar con tus valores reales.
# NUNCA commitear .env.local ni archivos con credenciales reales.
# Total de variables: 19 (7 servicios + App)
# =============================================================================

# ============================================================
# SUPABASE (4 variables)
# https://app.supabase.com
# ============================================================
# URL del proyecto Supabase (formato: https://xxxxx.supabase.co)
# Obtener en: https://app.supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key para el cliente browser
# Obtener en: https://app.supabase.com > Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key para operaciones server-side (NUNCA exponer al cliente)
# Obtener en: https://app.supabase.com > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# ID del proyecto Supabase (formato: xxxxx de la URL)
# Obtener en: https://app.supabase.com > Project Settings > General
SUPABASE_PROJECT_ID=

# ============================================================
# STRIPE (6 variables)
# https://dashboard.stripe.com
# ============================================================
# Secret key para operaciones server-side (formato: sk_test_... o sk_live_...)
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Publishable key para el cliente (formato: pk_test_... o pk_live_...)
# Obtener en: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Signing secret del webhook endpoint (formato: whsec_...)
# Obtener en: https://dashboard.stripe.com/webhooks > seleccionar endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=

# Price ID del plan semanal (formato: price_...)
# Obtener en: https://dashboard.stripe.com/products > seleccionar producto > Price ID
STRIPE_PRICE_WEEKLY=

# Price ID del plan mensual (formato: price_...)
# Obtener en: https://dashboard.stripe.com/products > seleccionar producto > Price ID
STRIPE_PRICE_MONTHLY=

# Price ID del Protocolo 100 días (formato: price_...)
# Obtener en: https://dashboard.stripe.com/products > seleccionar producto > Price ID
STRIPE_PRICE_PROTOCOL_100=

# ============================================================
# GEMINI AI (1 variable)
# https://aistudio.google.com
# ============================================================
# API key para Gemini 2.5 Flash, generación de avatares IA (formato: AIzaSy...)
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ============================================================
# SENTRY (1 variable)
# https://sentry.io
# ============================================================
# Data Source Name para error tracking (formato: https://xxx@xxx.ingest.sentry.io/xxx)
# Obtener en: https://sentry.io > Project Settings > Client Keys (DSN)
SENTRY_DSN=

# ============================================================
# POSTHOG (2 variables)
# https://app.posthog.com
# ============================================================
# Project API key para analytics (formato: phc_...)
# Obtener en: https://app.posthog.com > Project Settings > Project API Key
NEXT_PUBLIC_POSTHOG_KEY=

# Host URL de PostHog (default: https://app.posthog.com)
# Obtener en: https://app.posthog.com > Project Settings (o usar https://app.posthog.com si es cloud)
NEXT_PUBLIC_POSTHOG_HOST=

# ============================================================
# UPSTASH REDIS (2 variables)
# https://console.upstash.com
# ============================================================
# REST API URL de Upstash Redis (formato: https://xxx.upstash.io)
# Obtener en: https://console.upstash.com > seleccionar base de datos > REST API > URL
UPSTASH_REDIS_REST_URL=

# REST API token de Upstash Redis
# Obtener en: https://console.upstash.com > seleccionar base de datos > REST API > Token
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# INNGEST (2 variables)
# https://app.inngest.com
# ============================================================
# Event key para enviar eventos a Inngest
# Obtener en: https://app.inngest.com > Settings > Event Keys
INNGEST_EVENT_KEY=

# Signing key para verificar webhooks de Inngest
# Obtener en: https://app.inngest.com > Settings > Signing Key
INNGEST_SIGNING_KEY=

# ============================================================
# APP CONFIGURATION (1 variable)
# ============================================================
# URL base de la aplicación
# Desarrollo: http://localhost:3000
# Producción: https://metamen100.com
NEXT_PUBLIC_APP_URL=
