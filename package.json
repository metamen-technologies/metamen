{
  "name": "metamen100",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "supabase gen types typescript --local > src/types/database.types.ts",
    "db:seed": "supabase db reset --seed",
    "db:reset": "supabase db reset",
    "inngest:dev": "npx inngest-cli@latest dev",
    "clean": "rm -rf .next node_modules",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@google/generative-ai": "~0.21",
    "@hookform/resolvers": "~3.9",
    "@supabase/ssr": "~0.5",
    "@supabase/supabase-js": "~2.47",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "bullmq": "~5.34",
    "class-variance-authority": "~0.7",
    "clsx": "~2.0",
    "date-fns": "~4.1",
    "date-fns-tz": "~3.2",
    "framer-motion": "~11.15",
    "immer": "~10.0",
    "inngest": "~3.0",
    "lucide-react": "~0.469",
    "next": "~15.1.12",
    "react": "~19.0.4",
    "react-dom": "~19.0.4",
    "react-hook-form": "~7.54",
    "recharts": "~2.15",
    "sonner": "^2.0.7",
    "stripe": "~17.0",
    "tailwind-merge": "~2.0",
    "uuid": "~11.0",
    "zod": "~3.23",
    "zustand": "~5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "~16.1",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "~15.1.12",
    "fast-check": "~3.0",
    "husky": "^9.1.7",
    "playwright": "~1.40",
    "prettier": "~3.4",
    "supabase": "~2.0",
    "tailwindcss": "~4.0.17",
    "typescript": "~5.7.3",
    "vitest": "~2.1"
  }
}
